# go-database — Environment Variable Example (.env)
# Copy to .env and adjust. All vars use the GODB_ prefix.
# Real environment variables override these. .env is loaded at startup.
#
# ── Server ──
GODB_SERVER_HOST=0.0.0.0
GODB_SERVER_PORT=8080
GODB_SERVER_BASE_URL=http://localhost:8080
# CORS: comma-separated origins, or * for dev
GODB_SERVER_CORS_ORIGIN=*

# ── Auth ──
# Token lifetime in minutes
GODB_AUTH_TOKEN_DURATION=60
# IMPORTANT: set a strong secret in production (persists across restarts).
# Generate one with: openssl rand -hex 32
GODB_AUTH_JWT_SECRET=change-me-in-production

# ── Internal DB (auth store) ──
# SQLite (default):
GODB_INTERNAL_DB_AUTH_PATH=database/internal/auth.db
# OR PostgreSQL (uncomment to use Postgres instead of SQLite):
# GODB_INTERNAL_DB_AUTH_URL=postgres://user:password@localhost:5432/godb_auth

# ── Logging ──
GODB_LOG_LEVEL=info

# ── Data directory (root for internal/runtime DBs) ──
GODB_DATA_DIR=database/internal
