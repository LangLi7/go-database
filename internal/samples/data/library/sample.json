        {"id": 3, "member_id": 2, "book_id": 1, "loan_date": "2024-03-10", "due_date": "2024-03-24", "return_date": "2024-03-20"},
        {"id": 4, "member_id": 3, "book_id": 3, "loan_date": "2024-04-05", "due_date": "2024-04-19", "return_date": null},
        {"id": 5, "member_id": 3, "book_id": 4, "loan_date": "2024-04-05", "due_date": "2024-04-19", "return_date": "2024-04-18"}
      ]
    }
  ]
}
