{
  "name": "Company HR",
  "description": "Mitarbeiterverwaltung mit Abteilungen, Positionen und Hierarchie (Self-Join). Zeigt 1:N-Beziehungen und Self-Referencing.",
  "version": "1.0",
  "tables": [
    {
      "name": "departments",
      "comment": "Abteilungen der Firma",
      "columns": [
        {"name": "id", "type": "integer", "pk": true, "autoincrement": true},
        {"name": "name", "type": "text", "notnull": true, "unique": true},
        {"name": "location", "type": "text", "notnull": false},
        {"name": "budget", "type": "real", "notnull": false, "default": 0}
